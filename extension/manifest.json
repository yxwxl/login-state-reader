{
  "manifest_version": 3,
  "name": "登录态读取器",
  "version": "1.0.0",
  "description": "读取当前页面 Cookie，并复制 Playwright 可用的登录态。",
  "permissions": [
    "activeTab",
    "alarms",
    "cookies",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "登录态读取器",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
